{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/hooks-bin/optics_guard.py\"",
            "statusMessage": "Optics token guard…"
          },
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/hooks-bin/optics_classname_guard.py\"",
            "statusMessage": "Optics classname guard…"
          },
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/hooks-bin/optics_bem_guard.py\"",
            "statusMessage": "Optics BEM structure guard…"
          }
        ]
      }
    ]
  }
}
